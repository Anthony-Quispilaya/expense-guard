PORT=3001
NODE_ENV=development

# Supabase — get from https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# Knot — get from https://dashboard.knotapi.com/configuration
KNOT_CLIENT_ID=
KNOT_CLIENT_SECRET=
KNOT_ENVIRONMENT=development
# development or production

# Photon — iMessage alerts via @photon-ai/advanced-imessage (gRPC)
# Works from any platform (Linux/WSL2/macOS) — connects to a remote Photon Mac instance.
# 1. Have a team member on Mac start a Photon instance at https://photon.codes/dashboard
# 2. Copy the instance address (e.g. abc123.imsg.photon.codes:443) → PHOTON_ADDRESS
# 3. Copy the LightAuth token → PHOTON_TOKEN
PHOTON_ADDRESS=
PHOTON_TOKEN=
# Phone number to send alerts to (E.164 format)
PHOTON_TEST_NUMBER=+1XXXXXXXXXX

# Discord — optional second alert channel (works everywhere)
# Create: Discord channel → Edit → Integrations → Webhooks → New Webhook → Copy URL
DISCORD_WEBHOOK_URL=

# App URLs
APP_BASE_URL=http://localhost:5173
# For Knot webhooks during local dev, expose this backend with ngrok:
# ngrok http 3001 → copy the https URL here
WEBHOOK_BASE_URL=
