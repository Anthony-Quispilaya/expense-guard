PORT=3001
NODE_ENV=development

# Supabase — get from https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# Knot — get from https://dashboard.knotapi.com/configuration
KNOT_CLIENT_ID=
KNOT_CLIENT_SECRET=
KNOT_ENVIRONMENT=development
# development or production

# Photon — iMessage alerts via @photon-ai/advanced-imessage (gRPC, works from any platform)
# Use the "Client ID" (→ PHOTON_PROJECT_ID) and "Secret" (→ PHOTON_PROJECT_SECRET)
# from your Photon dashboard at https://photon.codes/dashboard
# The backend auto-fetches the token + server address — no other Photon config needed.
PHOTON_PROJECT_ID=
PHOTON_PROJECT_SECRET=
# Phone number to SEND alerts TO (E.164 format)
PHOTON_TEST_NUMBER=+1XXXXXXXXXX

# Discord — optional second alert channel (works everywhere)
# Create: Discord channel → Edit → Integrations → Webhooks → New Webhook → Copy URL
DISCORD_WEBHOOK_URL=

# App URLs
APP_BASE_URL=http://localhost:5173
# For Knot webhooks during local dev, expose this backend with ngrok:
# ngrok http 3001 → copy the https URL here
WEBHOOK_BASE_URL=
