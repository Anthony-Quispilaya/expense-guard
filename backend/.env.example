PORT=3001
NODE_ENV=development

# Supabase — get from https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# Knot — get from https://dashboard.knotapi.com/configuration
KNOT_CLIENT_ID=
KNOT_CLIENT_SECRET=
KNOT_ENVIRONMENT=development
# development or production

# Photon — the phone number to alert (E.164 format)
# NOTE: @photon-ai/imessage-kit is macOS-only.
# On Linux/WSL2 the send is skipped and logged as platform_unsupported.
# On macOS with Messages.app this will send a real iMessage.
PHOTON_TEST_NUMBER=+1XXXXXXXXXX

# App URLs
APP_BASE_URL=http://localhost:5173
# For Knot webhooks during local dev, expose this backend with ngrok:
# ngrok http 3001 → copy the https URL here
WEBHOOK_BASE_URL=
